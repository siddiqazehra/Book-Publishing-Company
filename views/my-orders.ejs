<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders - Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('partials/header') %>

    <section class="page-hero">
        <p class="page-eyebrow">Your Account</p>
        <h1>My Orders</h1>
    </section>

    <section class="orders-section">
        <div class="orders-wrap">
            <% if (!orders || orders.length === 0) { %>
                <p class="orders-empty">You haven't placed any orders yet. <a href="/books">Browse books</a> to get started.</p>
            <% } else { %>
                <% orders.forEach(function(order) { %>
                    <article class="order-card">
                        <header class="order-card-head">
                            <div class="order-card-meta">
                                <span class="order-id">Order #<%= order.orderId %></span>
                                <span class="order-date"><%= new Date(order.createdAt).toLocaleDateString() %></span>
                            </div>
                            <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
                        </header>
                        <div class="order-items-scroll">
                            <table class="order-items">
                                <thead>
                                    <tr>
                                        <th>Cover</th>
                                        <th>Title</th>
                                        <th>Unit Price</th>
                                        <th>Qty</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% order.items.forEach(function(item) { %>
                                        <tr>
                                            <td><img class="order-thumb" src="/<%= item.image %>" alt="<%= item.title %>"></td>
                                            <td class="order-item-title"><%= item.title %></td>
                                            <td>Rs. <%= item.price.toFixed(2) %></td>
                                            <td><%= item.quantity %></td>
                                            <td>Rs. <%= (item.price * item.quantity).toFixed(2) %></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4" class="order-total-label">Order Total</td>
                                        <td class="order-total-value">Rs. <%= order.totalAmount.toFixed(2) %></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </article>
                <% }); %>
            <% } %>
        </div>
    </section>

    <%- include('partials/footer', { books: [] }) %>
</body>

</html>
