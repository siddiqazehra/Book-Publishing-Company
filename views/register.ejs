<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('partials/header') %>

    <section id="auth-section">
        <div id="auth-parent">
            <h2>Create your account</h2>
            <p class="auth-subtext">Join Publishing Company to save books and track orders.</p>

            <div id="auth-message" class="<%= error ? 'error' : '' %>"><%= error || '' %></div>

            <form id="register-form" method="POST" action="/register" novalidate>
                <label for="name">Full name</label>
                <input type="text" id="name" name="name" placeholder="Jane Doe" value="<%= (formData && formData.name) || '' %>" required>

                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" value="<%= (formData && formData.email) || '' %>" required>

                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="At least 8 characters" required minlength="8">

                <label for="confirmPassword">Confirm password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter your password" required minlength="8">

                <button type="submit" class="button" id="blue-button">Create account</button>
            </form>

            <p id="auth-switch">Already have an account? <a href="/login">Log in</a></p>
        </div>
    </section>

    <%- include('partials/footer', { books: books || [] }) %>
</body>

</html>
