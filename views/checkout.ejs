<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('partials/header') %>

    <!-- BEGIN: Book Search & Cart Feature - simulated checkout page -->
    <section id="checkout-section">
        <div id="checkout-parent">
            <h1>Checkout</h1>
            <p id="checkout-demo-notice">You'll enter your card details securely on Safepay's payment page - we never
    see or store your card number.</p>

            <div id="checkout-layout">
                <div id="checkout-summary">
                    <h2>Order Summary</h2>
                    <div id="checkout-summary-items"></div>
                    <div id="checkout-summary-total"></div>
                </div>

                <form id="checkout-form">
                    <h2>Shipping Details</h2>
                    <input type="text" id="checkout-name" placeholder="Full Name" value="<%= user ? user.name : '' %>" required>
                    <input type="email" id="checkout-email" placeholder="Email Address" value="<%= user ? user.email : '' %>" required>
                    <input type="text" id="checkout-address" placeholder="Shipping Address" required>

<p id="checkout-error" class="error"></p>
<button type="submit" class="button" id="checkout-place-order">Continue to Payment</button>
                </form>
            </div>
        </div>
    </section>
    <!-- END: Book Search & Cart Feature - simulated checkout page -->

    <%- include('partials/footer', { books: books }) %>
    <script src="/js/checkout.js"></script>
</body>

</html>
