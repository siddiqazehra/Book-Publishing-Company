<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('partials/header') %>

    <!-- BEGIN: Book Search & Cart Feature - simulated checkout page -->
    <section id="checkout-section">
        <div id="checkout-parent">
            <h1>Checkout</h1>
            <p id="checkout-demo-notice">Pay easily with EasyPaisa, JazzCash, or Cash on Delivery. For mobile wallets, send the amount and enter your transaction ID.</p>

            <div id="checkout-layout">
                <div id="checkout-summary">
                    <h2>Order Summary</h2>
                    <div id="checkout-summary-items"></div>
                    <div id="checkout-summary-total"></div>
                </div>

                <form id="checkout-form">
                    <h2>Shipping Details</h2>
                    <input type="text" id="checkout-name" placeholder="Full Name" value="<%= user ? user.name : '' %>" required>
                    <input type="email" id="checkout-email" placeholder="Email Address" value="<%= user ? user.email : '' %>" required>
                    <input type="text" id="checkout-address" placeholder="Shipping Address" required>

                    <h2>Payment Method</h2>
                    <div class="pay-methods">
                        <label class="pay-opt">
                            <img class="pay-logo" src="/images/easypaisa.svg" alt="EasyPaisa">
                            <span class="pay-name">EasyPaisa</span>
                            <input type="radio" name="paymentMethod" value="easypaisa" checked>
                        </label>
                        <label class="pay-opt">
                            <img class="pay-logo" src="/images/jazzcash.svg" alt="JazzCash">
                            <span class="pay-name">JazzCash</span>
                            <input type="radio" name="paymentMethod" value="jazzcash">
                        </label>
                        <label class="pay-opt">
                            <span class="pay-logo pay-cod">COD</span>
                            <span class="pay-name">Cash on Delivery</span>
                            <input type="radio" name="paymentMethod" value="cash">
                        </label>
                    </div>

                    <div id="pay-easypaisa" class="pay-info" hidden>
                        Send <strong id="pay-total-ep"></strong> to EasyPaisa
                        <strong><%= payment.easypaisa.number || 'N/A' %></strong>
                        <% if (payment.easypaisa.name) { %>(<%= payment.easypaisa.name %>)<% } %>,
                        then enter your transaction ID below.
                    </div>
                    <div id="pay-jazzcash" class="pay-info" hidden>
                        Send <strong id="pay-total-jc"></strong> to JazzCash
                        <strong><%= payment.jazzcash.number || 'N/A' %></strong>
                        <% if (payment.jazzcash.name) { %>(<%= payment.jazzcash.name %>)<% } %>,
                        then enter your transaction ID below.
                    </div>
                    <input type="text" id="checkout-reference" placeholder="Transaction ID (EasyPaisa/JazzCash)" hidden>

                    <p id="checkout-error" class="error"></p>
                    <button type="submit" class="button" id="checkout-place-order">Place Order</button>
                </form>
            </div>
        </div>

        <div id="checkout-confirmation" hidden>
            <h2>Order placed!</h2>
            <p id="checkout-confirmation-msg"></p>
            <a href="/my-orders" class="button">View my orders</a>
        </div>
    </section>
    <!-- END: Book Search & Cart Feature - simulated checkout page -->

    <%- include('partials/footer', { books: books }) %>
    <script src="/js/checkout.js"></script>
</body>

</html>
