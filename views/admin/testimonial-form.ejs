<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Publishing Company</title>
  <link rel="stylesheet" href="/style.css"><link rel="stylesheet" href="/admin.css">
</head>
<body>
  <div id="admin-shell">
    <%- include('../partials/admin-sidebar', { active: 'testimonials' }) %>
    <main id="admin-main">
      <div id="admin-topbar"><h1><%= mode === 'create' ? 'Add Testimonial' : 'Edit Testimonial' %></h1><div class="admin-user">Signed in as <strong><%= user.name %></strong></div></div>
      <div class="admin-panel" style="max-width: 620px;">
        <% if (error) { %><div class="admin-error"><%= error %></div><% } %>
        <form class="admin-form" method="POST" action="<%= mode === 'create' ? '/admin/testimonials' : '/admin/testimonials/' + testimonial._id + '/update' %>">
          <label for="name">Client name</label>
          <input type="text" id="name" name="name" value="<%= testimonial.name || '' %>" required maxlength="120">
          <label for="role">Role / title</label>
          <input type="text" id="role" name="role" value="<%= testimonial.role || '' %>" placeholder="e.g. Reader, Author, Manager" maxlength="80">
          <label for="message">Message</label>
          <textarea id="message" name="message" required maxlength="600"><%= testimonial.message || '' %></textarea>
          <label for="image">Photo path (optional)</label>
          <input type="text" id="image" name="image" value="<%= testimonial.image || '' %>" placeholder="images/author-img-1.jpg">
          <span class="admin-hint">Leave blank to use initials as the avatar.</span>
          <div class="admin-form-actions">
            <button type="submit" class="btn-sm btn-add" style="padding:10px 24px;"><%= mode === 'create' ? 'Add Testimonial' : 'Save Changes' %></button>
            <a href="/admin/testimonials" class="btn-sm btn-edit" style="padding:10px 24px;">Cancel</a>
          </div>
        </form>
      </div>
    </main>
  </div>
</body>
</html>
