<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/admin.css">
</head>

<body>
    <div id="admin-shell">
        <%- include('../partials/admin-sidebar', { active: 'books' }) %>

        <main id="admin-main">
            <div id="admin-topbar">
                <h1><%= mode === 'create' ? 'Add Book' : 'Edit Book' %></h1>
                <div class="admin-user">Signed in as <strong><%= user.name %></strong></div>
            </div>

            <div class="admin-panel" style="max-width: 640px;">
                <% if (error) { %>
                    <div class="admin-error"><%= error %></div>
                <% } %>

                <form class="admin-form" method="POST" enctype="multipart/form-data"
                    action="<%= mode === 'create' ? '/admin/books' : '/admin/books/' + book._id + '/update' %>">

                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" value="<%= book.title || '' %>" required maxlength="200">

                    <label for="author">Author</label>
                    <input type="text" id="author" name="author" value="<%= book.author || '' %>" required maxlength="120">

                    <label for="genre">Genre</label>
                    <select id="genre" name="genre">
                      <option value="">— Select a genre —</option>
                      <% genres.forEach(function(g) { %>
                        <option value="<%= g %>" <%= book.genre === g ? 'selected' : '' %>><%= g %></option>
                      <% }); %>
                    </select>
                    <input type="text" name="genreNew" placeholder="…or type a new genre" maxlength="80">
                    <small class="admin-hint">If you type a new genre, it is used instead of the dropdown selection.</small>

                    <label for="price">Price ($)</label>
                    <input type="number" id="price" name="price" value="<%= book.price || '' %>" required min="0" step="0.01">

                    <label for="stock">Stock (copies available)</label>
                    <input type="number" id="stock" name="stock" value="<%= book.stock || 0 %>" min="0" step="1">

                    <label for="cover">Upload cover image (from your computer)</label>
                    <input type="file" id="cover" name="cover" accept="image/*">
                    <% if (book.image) { %>
                      <div class="admin-current-cover">Current: <img class="thumb" src="/<%= book.image %>" alt=""></div>
                    <% } %>
                    <small class="admin-hint">Leave this empty to keep the current cover (or the default cover for a new book).</small>

                    <label for="description">Description</label>
                    <textarea id="description" name="description" maxlength="2000"><%= book.description || '' %></textarea>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn-sm btn-add" style="padding:10px 24px;">
                            <%= mode === 'create' ? 'Add Book' : 'Save Changes' %>
                        </button>
                        <a href="/admin/books" class="btn-sm btn-edit" style="padding:10px 24px;">Cancel</a>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>

</html>
