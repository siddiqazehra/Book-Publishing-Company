<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/admin.css">
</head>

<body>
    <div id="admin-shell">
        <%- include('../partials/admin-sidebar', { active: 'users' }) %>

        <main id="admin-main">
            <div id="admin-topbar">
                <h1>Manage Users</h1>
                <div class="admin-user">Signed in as <strong><%= user.name %></strong></div>
            </div>

            <div class="admin-panel">
                <div class="admin-toolbar">
                    <div></div>
                    <a href="/admin/users/new" class="btn-sm btn-add">+ Add User</a>
                </div>

                <% if (!users || users.length === 0) { %>
                    <p class="admin-empty">No users found.</p>
                <% } else { %>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Joined</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(function(u) { %>
                                <tr>
                                    <td><%= u.userId %></td>
                                    <td><%= u.name %></td>
                                    <td><%= u.email %></td>
                                    <td><span class="status-badge <%= u.accessLevel === 'master' ? 'status-shipped' : 'status-pending' %>"><%= u.accessLevel === 'master' ? 'Admin' : 'Customer' %></span></td>
                                    <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                                    <td class="table-actions">
                                        <div class="table-actions-inner">
                                            <a class="btn-sm btn-edit" href="/admin/users/<%= u._id %>/edit">Edit</a>
                                            <% if (String(u._id) !== String(user._id)) { %>
                                                <form action="/admin/users/<%= u._id %>/delete" method="POST" onsubmit="return confirm('Delete this user? This cannot be undone.');">
                                                    <button type="submit" class="btn-sm btn-delete">Delete</button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </main>
    </div>
</body>

</html>
