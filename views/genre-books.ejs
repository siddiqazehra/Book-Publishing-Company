<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= genreName %> Books — Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('partials/header') %>

    <section id="contact-img">
        <div id="contact-content">
            <p>HOME &gt; GENRES &gt; <%= genreName %></p>
            <h1><%= genreName %></h1>
        </div>
    </section>

    <section id="top-sellers">
        <div id="seller-parent">
            <div id="seller-heading">
                <p class="orange-text">GENRE</p>
                <h2 class="welcome-heading"><%= genreName %> Books</h2>
            </div>

            <% if (genreBooks.length === 0) { %>
                <p style="text-align:center; font-family: var(--roboto); color: gray; padding: 40px 0;">
                    No <%= genreName %> books yet — check back soon, or browse
                    <a href="/#new-release" style="color: var(--dark-gray);">all new releases</a> instead.
                </p>
            <% } else { %>
                <div id="seller-book-card">
                    <div class="seller-rows">
                        <% genreBooks.forEach(function(book) { %>
                            <a class="seller-book" href="/book-details?id=<%= book._id %>">
                                <div class="seller-book-img">
                                    <img src="/<%= book.image %>" alt="<%= book.title %>">
                                </div>
                                <div class="seller-book-info">
                                    <p class="orange-text">$ <%= book.price.toFixed(2) %></p>
                                    <h2><%= book.title %></h2>
                                    <p>By <%= book.author %></p>
                                </div>
                            </a>
                        <% }); %>
                    </div>
                </div>
            <% } %>
        </div>
    </section>

    <%- include('partials/footer', { books: books }) %>
</body>

</html>
