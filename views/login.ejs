<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('partials/header') %>

    <section id="auth-section">
        <div id="auth-parent">
            <h2>Welcome back</h2>
            <p class="auth-subtext">Log in to your Publishing Company account.</p>

            <div id="auth-message" class="<%= error ? 'error' : (notice ? 'success' : '') %>"><%= error || notice || '' %></div>

            <form id="login-form" method="POST" action="/login" novalidate>
                <input type="hidden" name="next" value="<%= next || '/' %>">

                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>

                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Your password" required>

                <button type="submit" class="button" id="blue-button">Log in</button>
            </form>

            <p id="auth-switch">Don't have an account? <a href="/register">Register</a></p>
        </div>
    </section>

    <%- include('partials/footer', { books: books || [] }) %>
</body>

</html>
