<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Publishing Company</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/jquery-3.7.1.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="/jquery-validation-1.21.0/dist/jquery.validate.min.js"></script>

</head>

<body>
    <%- include('partials/header') %>

    <section class="page-hero">
        <p class="page-eyebrow">Get in Touch</p>
        <h1>Contact Us</h1>
    </section>
    <section id="logo-section">
        <div id="logo-parent">
            <div class="logo-div">
                <a href="https://maps.app.goo.gl/FiGbRoxcZKeZNHKv7" target="_blank"><img src="/images/contact-logo-1.png"
                        alt="Location of Consulnet Corporation"></a>
                <p>Address: <span class="blue-text">St 1, PECHS, Karachi</span></p>
            </div>
            <div class="logo-div">
                <a href="tel:+92000000000" target="_blank"><img src="/images/contact-logo-2.png" alt="Invalid contact number"></a>
                <p>Phone: <span class="blue-text">+92 000 000000</span></p>
            </div>
            <div class="logo-div">
                <a href="mailto:publishingcompany@gmail.com"><img src="/images/contact-logo-3.png" alt="Invalid Email"></a>
                <p>Email: <span class="blue-text">publishingcompany@gmail.com</span></p>
            </div>
            <div class="logo-div">
                <a href="/"><img src="/images/contact-logo-4.png" alt="Publishing Company's Website"></a>
                <p>Website: <span class="blue-text">publishingcompany.com</span></p>
            </div>
        </div>
    </section>
    <section id="form-section">
        <div id="form-parent">
            <div id="maps">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3619.5465895760435!2d67.05664877443034!3d24.879330844503986!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3eb33eed5d2a946f%3A0x86b0b26ae2d6432b!2sConsulNet%20Corporation!5e0!3m2!1sen!2s!4v1766676690854!5m2!1sen!2s"
                    width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
            <div class="form-div">
                <h2>Contact Us</h2>
                <form id="contactForm" action="/contact" method="POST">
                    <label id="blue-text">Full Name</label>
                    <input type="text" name="name" placeholder="Name"><br>

                    <label id="blue-text">Email Address</label>
                    <input type="email" name="email" placeholder="Email"><br>

                    <label id="blue-text">Subject</label>
                    <input type="text" name="subject" placeholder="Subject"><br>

                    <label id="blue-text">Message</label>
                    <textarea name="message" rows="4" placeholder="Message"></textarea><br>

                    <button type="submit" id="form-button">Send Message</button>
                    <div id="responseMessage"></div>
                </form>
            </div>
        </div>
    </section>
    <section id="faqs">
        <h2>Frequently Asked Questions</h2>
        <div id="accordion">
            <h3>Do you publish new authors?</h3>
            <div>
                <p>Yes! We welcome both new and experienced writers to submit their work.</p>
            </div>
            <h3>Will I keep the rights to my book?</h3>
            <div>
                <p>Yes, authors retain the rights to their work unless stated otherwise.</p>
            </div>
            <h3>How long does the publishing process take?</h3>
            <div>
                <p>The process usually takes a few months, depending on the project.</p>
            </div>
            <h3>How can I submit my manuscript?</h3>
            <div>
                <p>You can submit your manuscript through our website or contact us by email.</p>
            </div>
        </div>
    </section>

    <%- include('partials/footer', { books: books }) %>

    <script>
        //Accordion ->
        $(function () {
            $("#accordion").accordion();
        });
        //form validation + AJAX submit (so the page doesn't reload)
        $("#contactForm").validate({
            rules: {
                name: { required: true },
                email: { required: true, email: true },
                subject: { required: true },
                message: { required: true }
            },
            messages: {
                name: { required: "This field is required" },
                email: { required: "This field is required", email: "A valid email is required" },
                subject: { required: "This field is required" },
                message: { required: "This field is required" }
            },
            submitHandler: function (form) {
                const submitBtn = $("#form-button");
                submitBtn.prop("disabled", true).text("Sending...");

                $.ajax({
                    url: "/contact",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({
                        name: $("input[name='name']").val(),
                        email: $("input[name='email']").val(),
                        subject: $("input[name='subject']").val(),
                        message: $("textarea[name='message']").val()
                    }),
                    success: function () {
                        $("#responseMessage").html("Message sent successfully!").css({ color: "green", marginTop: "10px" });
                        form.reset();
                        submitBtn.prop("disabled", false).text("Send Message");
                    },
                    error: function () {
                        $("#responseMessage").html("Failed to send message.").css({ color: "red", marginTop: "10px" });
                        submitBtn.prop("disabled", false).text("Send Message");
                    }
                });
            }
        });
    </script>
</body>

</html>
